{
  "name": "create-theo",
  "version": "0.1.0",
  "description": "Create a new Theo project with zero config",
  "type": "module",
  "bin": {
    "create-theo": "dist/index.js"
  },
  "files": [
    "dist",
    "templates"
  ],
  "scripts": {
    "build": "node scripts/copy-templates.js && tsc",
