{
  "name": "create-theo",
  "version": "0.2.1",
  "description": "Create a new Theo project with zero config",
  "type": "module",
  "bin": {
    "create-theo": "index.js"
  },
  "files": [
    "index.js",
    "dist",
    "templates"
  ],
  "scripts": {
    "build": "node scripts/copy-templates.js && unbuild",
    "dev": "unbuild --stub",
    "test": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js",
    "prepack": "node scripts/dont-publish-alpha-as-latest.cjs",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "theo",
    "deploy",
    "paas",
    "kubernetes",
    "scaffold",
    "create"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/usetheodev/theo-stacks"
  },
  "homepage": "https://usetheo.dev",
  "engines": {
    "node": ">=20.9"
  },
  "devDependencies": {
    "@inquirer/prompts": "^8.4.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^25.0.0",
    "chalk": "^5.4.0",
    "degit": "^2.8.4",
    "jest": "^29.7.0",
    "ora": "^9.3.0",
    "ts-jest": "^29.4.9",
    "typescript": "^5.9.0",
    "unbuild": "^3.6.1"
  }
}
