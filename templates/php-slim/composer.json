{
  "name": "theo/{{project-name}}",
  "description": "Slim API server scaffolded by Theo",
  "type": "project",
  "require": {
    "php": ">=8.1",
    "slim/slim": "^4.0",
    "slim/psr7": "^1.0",
    "monolog/monolog": "^3.0",
    "php-di/php-di": "^7.0"
  },
  "require-dev": {
    "phpstan/phpstan": "^1.0",
    "squizlabs/php_codesniffer": "^3.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "scripts": {
    "start": "php -S 0.0.0.0:8000 -t public",
    "dev": "php -S 0.0.0.0:8000 -t public",
    "lint": "phpstan analyse src --level=5",
    "cs": "phpcs --standard=PSR12 src/"
  }
}
